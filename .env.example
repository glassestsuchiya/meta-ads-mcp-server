# Meta Marketing API Credentials
# Get your access token from: https://developers.facebook.com/tools/explorer/

# Required: Access Token (User Access Token or System User Token)
META_ADS_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxx

# Optional: App ID and App Secret (for token refresh)
META_ADS_APP_ID=your_app_id
META_ADS_APP_SECRET=your_app_secret

# Optional: Default Ad Account ID (with act_ prefix)
META_ADS_DEFAULT_ACCOUNT_ID=act_123456789
